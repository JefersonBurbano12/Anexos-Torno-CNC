function sheets = get_sheet_names(f)

try
    sheets = sheetnames(f);
catch
    [~,sheets] = xlsfinfo(f);
    sheets = string(sheets);
end

end

function col = find_column(T, cands)

col = '';
vars = T.Properties.VariableNames;

for i = 1:numel(cands)
    ix = find(strcmpi(vars,cands{i}),1);
    if ~isempty(ix)
        col = vars{ix};
        return;
    end
end

end

function val = read_param_from_excel(f, names, def)

val = def;

try
    sheets = get_sheet_names(f);

    if ~any(strcmpi(sheets,'Parametros'))
        return;
    end

    P = readtable(f,'Sheet','Parametros','VariableNamingRule','preserve');
    vars = P.Properties.VariableNames;

    for i = 1:numel(vars)
        for j = 1:numel(names)
            if strcmpi(vars{i},names{j})
                v = to_double(P.(vars{i})(1));
                if isfinite(v)
                    val = v;
                    return;
                end
            end
        end
    end

    ni = [];
    vi = [];

    for i = 1:numel(vars)
        vl = lower(vars{i});

        if contains(vl,'param') || ...
           contains(vl,'name') || ...
           contains(vl,'variable') || ...
           contains(vl,'nombre')
            ni = i;
        end

        if contains(vl,'valor') || contains(vl,'value')
            vi = i;
        end
    end

    if ~isempty(ni) && ~isempty(vi)

        pN = string(P.(vars{ni}));
        pV = P.(vars{vi});

        for i = 1:numel(pN)
            for j = 1:numel(names)
                if strcmpi(strtrim(pN(i)),names{j})
                    v = to_double(pV(i));
                    if isfinite(v)
                        val = v;
                        return;
                    end
                end
            end
        end

    end

catch
end

end

function val = to_double(x)

if isnumeric(x)
    val = double(x(1));
elseif iscell(x)
    val = str2double(char(x{1}));
elseif isstring(x)
    val = str2double(char(x(1)));
elseif ischar(x)
    val = str2double(x);
else
    val = NaN;
end

end

function K = fill_nearest(K, mask)

idxOk = find(mask);
idxZ  = find(~mask);

if isempty(idxOk) || isempty(idxZ)
    return;
end

for i = 1:numel(idxZ)
    [~,n] = min(abs(idxOk-idxZ(i)));
    K(idxZ(i)) = K(idxOk(n));
end

end

function z_safe = apply_carriage_scurve_limiter(z_target, z0, vLimitSafe, dt, z_min, z_max)

N = numel(z_target);

z_safe = zeros(N,1);
z_safe(1) = clamp_value(z0, z_min, z_max);

for k = 2:N

    target = clamp_value(z_target(k), z_min, z_max);

    maxStep = abs(vLimitSafe(k)) * dt;
    maxStep = max(maxStep, 1e-9);

    dz = target - z_safe(k-1);

    dz = clamp_value(dz, -maxStep, maxStep);

    z_safe(k) = z_safe(k-1) + dz;

    z_safe(k) = clamp_value(z_safe(k), z_min, z_max);

end

end

function [theta_real, z_real, z_cmd, z_cmd_nom] = sim_primer_orden_anclado( ...
    theta_ref, z_ref, K_sync, dt, tau_m, tau_s, ...
    z_min, z_max, vLimitSafe_mm_s)

N = numel(theta_ref);

theta_real = zeros(N,1);
z_real     = zeros(N,1);
z_cmd      = zeros(N,1);
z_cmd_nom  = zeros(N,1);

theta_real(1) = theta_ref(1);
z_real(1)     = z_ref(1);
z_cmd(1)      = z_ref(1);
z_cmd_nom(1)  = z_ref(1);

am  = min(dt/tau_m, 0.99);
as  = min(dt/tau_s, 0.99);
Kff = tau_s;

v_ref = gradient(z_ref, dt);

for k = 2:N

    theta_real(k) = theta_real(k-1) + ...
        am*(theta_ref(k) - theta_real(k-1));

    theta_error = theta_real(k) - theta_ref(k);

    z_cmd_nom(k) = z_ref(k) + K_sync(k)*theta_error + Kff*v_ref(k);
    z_cmd_nom(k) = clamp_value(z_cmd_nom(k), z_min, z_max);

    maxStep = abs(vLimitSafe_mm_s(k)) * dt;
    maxStep = max(maxStep, 1e-9);

    dz = z_cmd_nom(k) - z_cmd(k-1);
    dz = clamp_value(dz, -maxStep, maxStep);

    z_cmd(k) = z_cmd(k-1) + dz;
    z_cmd(k) = clamp_value(z_cmd(k), z_min, z_max);

    z_real(k) = z_real(k-1) + as*(z_cmd(k) - z_real(k-1));
    z_real(k) = clamp_value(z_real(k), z_min, z_max);

end

end

function set_axis_limits(ax, xLim, yData, margin)

axes(ax);
xlim(xLim);
ylim(lim_with_margin(yData, margin));

end

function lims = lim_with_margin(data, margin)

data = data(isfinite(data));

if isempty(data)
    lims = [-1,1];
    return;
end

yMn = min(data);
yMx = max(data);

lims = [yMn-margin, yMx+margin];

end

function safe_yline(val, style, lbl)

if exist('yline','file') == 2

    if isempty(lbl)
        yline(val,style);
    else
        yline(val,style,lbl);
    end

else

    xl = xlim;
    plot(xl,[val val],style,'LineWidth',1.0);

    if ~isempty(lbl)
        text(xl(2),val,['  ' lbl]);
    end

end

end

function mark_helical_zones(t, isHel)

if ~any(isHel)
    return;
end

yl = ylim;

starts = find(diff([0;isHel(:)]) == 1);
ends   = find(diff([isHel(:);0]) == -1);

for i = 1:numel(starts)

    x1 = t(starts(i));
    x2 = t(ends(i));

    patch([x1 x2 x2 x1], ...
          [yl(1) yl(1) yl(2) yl(2)], ...
          [0.85 0.85 0.85], ...
          'FaceAlpha',0.3, ...
          'EdgeColor','none', ...
          'HandleVisibility','off');

end

end

function mark_limit_zones(t, limitScalePct)

active = limitScalePct < 99;

if ~any(active)
    return;
end

yl = ylim;

starts = find(diff([0;active(:)]) == 1);
ends   = find(diff([active(:);0]) == -1);

for i = 1:numel(starts)

    x1 = t(starts(i));
    x2 = t(ends(i));

    patch([x1 x2 x2 x1], ...
          [yl(1) yl(1) yl(2) yl(2)], ...
          [1.0 0.75 0.75], ...
          'FaceAlpha',0.25, ...
          'EdgeColor','none', ...
          'HandleVisibility','off');

end

end

function y = clamp_value(x, xmin, xmax)

y = min(max(x, xmin), xmax);

end

function y = smootherstep(x)

x = max(0, min(1, x));

% smootherstep = 6x^5 - 15x^4 + 10x^3
y = x.^3 .* (x .* (x*6 - 15) + 10);

end
