function OUT = fw_control_maestro_esclavo_de_xlsx()
%FW_CONTROL_MASTER_SLAVE_FROM_XLSX_REAL_CONTROL
% Control maestro-esclavo para maquina filament winding 2 ejes - CILINDRO.
%
% Maestro : mandril  (eje rotativo)
% Esclavo : carrito  (eje lineal)
%
% LOGICA CORRECTA:
%   1. Mandril baja en helicoidales.
%   2. Mandril NO baja por limites del carrito.
%   3. Carrito baja en helicoidales.
%   4. Carrito baja adicionalmente en limites y reversas.
%   5. La S-curve actua sobre el comando seguro del carrito.
%   6. El 3D muestra la respuesta real corregida.
%   7. Las graficas muestran referencia, comando seguro y respuesta real.

clc;

%  1. SELECCIONAR XLSX
%% -----------------------------------------------------------------------

[fileName, filePath] = uigetfile( ...
    {'*.xlsx;*.xls','Archivos Excel (*.xlsx, *.xls)'}, ...
    'Seleccionar archivo de trayectoria');

if isequal(fileName, 0)
    error('No se selecciono ningun archivo.');
end

xlsxFile = fullfile(filePath, fileName);

%  2. LEER HOJA
%% ----------------------------------------------------------------------

sheets = get_sheet_names(xlsxFile);

if any(strcmpi(sheets,'Controlador'))
    sheetName = 'Controlador';
elseif any(strcmpi(sheets,'Trayectoria'))
    sheetName = 'Trayectoria';
else
    error('No hay hoja Controlador ni Trayectoria.');
end

T = readtable(xlsxFile, 'Sheet', sheetName);


%  3. DETECTAR COLUMNAS
%% -----------------------------------------------------------------------

rotCol = find_column(T, { ...
    'Mandrel_Rotation_deg', ...
    'Mandrel_Rotation', ...
    'Rotation_deg', ...
    'Theta_deg', ...
    'Rotacion_Mandril_deg'});

linCol = find_column(T, { ...
    'Carriage_Position_mm', ...
    'Carriage_Position', ...
    'Position_mm', ...
    'Z_mm', ...
    'Posicion_Carro_mm'});

timeCol = find_column(T, { ...
    'Time_s', ...
    'Time', ...
    't_s', ...
    'Tiempo_s'});

if isempty(rotCol)
    error('No se encontro columna de rotacion del mandril.');
end

if isempty(linCol)
    error('No se encontro columna de posicion del carrito.');
end

theta_ref_raw = double(T.(rotCol));
z_ref_raw     = double(T.(linCol));

theta_ref_raw = theta_ref_raw(:);
z_ref_raw     = z_ref_raw(:);

if isempty(timeCol)
    t_raw_orig = (0:numel(theta_ref_raw)-1)' * 0.05;
else
    t_raw_orig = double(T.(timeCol));
    t_raw_orig = t_raw_orig(:);
end

%  4. CONFIGURACION DEL USUARIO
%% -----------------------------------------------------------------------

%  VELOCIDAD GENERAL DE LA MAQUINA

SpeedPercent_User = 10;        % Cambiar aqui: 0 a 100 [%]

%  REDUCCION EN TRAYECTORIAS HELICOIDALES

HelicalSpeedPercent_User = 30; % 1 a 100 [%]

% Ejemplo:
% SpeedPercent_User = 10
% HelicalSpeedPercent_User = 30
% Velocidad efectiva helicoidal = 3 %

%  LIMITES REALES DE MAQUINA

MandrelMax_rpm   = 150;        % mandril: -150 a +150 rpm
CarriageMax_mm_s = 762;        % carrito: -762 a +762 mm/s

%  S-CURVE DEL CARRITO EN LIMITES Y REVERSAS

SCurve_decel_pct     = 0.12;   % 12 % del recorrido por extremo
SCurve_decel_min     = 80;     % distancia minima de desaceleracion [mm]
SCurve_limit_min_pct = 0.05;   % velocidad minima cerca del limite = 5 %

ReverseSpeedPercent  = 0.12;   % velocidad local maxima en reversa = 12 %

AnimationTimeScale = 0.025;    % mayor = animacion mas lenta

%  VALIDACION

SpeedPercent        = min(max(SpeedPercent_User, 0), 100);
HelicalSpeedPercent = min(max(HelicalSpeedPercent_User, 1), 100);

MandrelMax_rpm   = abs(MandrelMax_rpm);
CarriageMax_mm_s = abs(CarriageMax_mm_s);

zeroSpeedMode = SpeedPercent <= 0;

MandrelMax_deg_s = MandrelMax_rpm * 360 / 60;
MandrelMax_rad_s = MandrelMax_rpm * 2*pi / 60;

%  5. LIMPIAR Y ORDENAR DATOS
%% -----------------------------------------------------------------------

valid = isfinite(t_raw_orig) & ...
        isfinite(theta_ref_raw) & ...
        isfinite(z_ref_raw);

t_raw_orig    = t_raw_orig(valid);
theta_ref_raw = theta_ref_raw(valid);
z_ref_raw     = z_ref_raw(valid);

if numel(theta_ref_raw) < 2
    error('Menos de 2 puntos validos en la trayectoria.');
end

[t_raw_orig, ix] = sort(t_raw_orig);
theta_ref_raw = theta_ref_raw(ix);
z_ref_raw     = z_ref_raw(ix);

[t_raw_orig, iu] = unique(t_raw_orig,'stable');
theta_ref_raw = theta_ref_raw(iu);
z_ref_raw     = z_ref_raw(iu);

if numel(theta_ref_raw) < 2
    error('Despues de limpiar, quedan menos de 2 puntos validos.');
end

%  6. RECALCULAR TIEMPO DE SINCRONISMO
% ------------------------------------------------------------------------
%  Logica correcta:
%
%  Mandril:
%     - SpeedPercent en zonas normales.
%     - SpeedPercent * HelicalSpeedPercent en helicoidales.
%     - NO baja por limites del carrito.
%
%  Carrito:
%     - SpeedPercent en zonas normales.
%     - SpeedPercent * HelicalSpeedPercent en helicoidales.
%     - Baja adicionalmente cerca de z_min, z_max y reversas.
%% -----------------------------------------------------------------------

SyncSafetyFactor = 1.60;
MinSegmentTime   = 0.040;

nRaw = numel(theta_ref_raw);

t_raw             = zeros(nRaw,1);
isHelical_raw     = false(nRaw,1);
isReverse_raw     = false(nRaw,1);
localSpeedPct_raw = zeros(nRaw,1);
limitScalePct_raw = 100*ones(nRaw,1);
mandrelSpeedPct_raw = zeros(nRaw,1);

z_min_raw  = min(z_ref_raw);
z_max_raw  = max(z_ref_raw);
z_span_raw = z_max_raw - z_min_raw;

decel_dist_raw = max(z_span_raw * SCurve_decel_pct, SCurve_decel_min);

if zeroSpeedMode

    warning('SpeedPercent = 0. Maquina lista, sin movimiento.');
    t_raw = (0:nRaw-1)' * 0.05;
    localSpeedPct_raw(:) = 0;
    limitScalePct_raw(:) = 0;
    mandrelSpeedPct_raw(:) = 0;

else

    sf = SpeedPercent / 100;
    dz_prev = 0;

    for k = 2:nRaw

        dth = theta_ref_raw(k) - theta_ref_raw(k-1);
        dz  = z_ref_raw(k)     - z_ref_raw(k-1);

        % Detectar helicoidal: rotacion y desplazamiento al mismo tiempo
        helicoidal = abs(dth) > 1e-6 && abs(dz) > 1e-6;
        isHelical_raw(k) = helicoidal;

        if helicoidal
            helicalFactor = HelicalSpeedPercent / 100;
        else
            helicalFactor = 1.0;
        end

        % Detectar reversa del carrito
        reverseNow = abs(dz_prev) > 1e-9 && ...
                     abs(dz) > 1e-9 && ...
                     sign(dz_prev) ~= sign(dz);

        isReverse_raw(k) = reverseNow;

        if abs(dz) > 1e-9
            dz_prev = dz;
        end

        % ------------------------------------------------------------
        % Mandril:
        % baja en helicoidales, baja por limites del carrito
        % ------------------------------------------------------------
        mandrelSpeedFactor = sf * helicalFactor;

        % ------------------------------------------------------------
        % Carrito:
        % baja en helicoidales y baja adicional por limites
        % ------------------------------------------------------------

        z_mid = 0.5 * (z_ref_raw(k) + z_ref_raw(k-1));

        dist_to_limit = min(z_mid - z_min_raw, z_max_raw - z_mid);
        dist_to_limit = max(dist_to_limit, 0);

        q = dist_to_limit / max(decel_dist_raw, eps);
        q = clamp_value(q, 0, 1);

        % S-curve del carrito
        sLim = smootherstep(q);

        limitFactor = SCurve_limit_min_pct + ...
            (1 - SCurve_limit_min_pct) * sLim;

        if reverseNow
            limitFactor = min(limitFactor, max(SCurve_limit_min_pct, ReverseSpeedPercent));
        end

        carriageSpeedFactor = sf * helicalFactor * limitFactor;

        mandrelSpeedFactor  = clamp_value(mandrelSpeedFactor,  1e-5, 1);
        carriageSpeedFactor = clamp_value(carriageSpeedFactor, 1e-5, 1);

        mandrelSpeedPct_raw(k) = mandrelSpeedFactor * 100;
        localSpeedPct_raw(k)   = carriageSpeedFactor * 100;
        limitScalePct_raw(k)   = limitFactor * 100;

        % Limites locales
        omLim = MandrelMax_deg_s * mandrelSpeedFactor / SyncSafetyFactor;
        vLim  = CarriageMax_mm_s * carriageSpeedFactor / SyncSafetyFactor;

        omLim = max(omLim, 1e-6);
        vLim  = max(vLim, 1e-6);

        % Tiempo:
        % Si hay giro, manda el mandril.
        % Si no hay giro, manda el carrito.
        if abs(dth) > 1e-9
            dt_rot = abs(dth) / omLim;
            dts = max(dt_rot, MinSegmentTime);
        else
            dt_car = abs(dz) / vLim;
            dts = max(dt_car, MinSegmentTime);
        end

        if ~isfinite(dts) || dts <= 0
            dts = MinSegmentTime;
        end

        t_raw(k) = t_raw(k-1) + dts;

    end

end

%  7. REMUESTREO A TIEMPO UNIFORME
%% -----------------------------------------------------------------------

dtvec = diff(t_raw);
dtvec = dtvec(dtvec > 0 & isfinite(dtvec));

if isempty(dtvec)
    dt = 0.05;
else
    dt = max(median(dtvec), 1e-4);
end

t0 = t_raw(1);
tF = t_raw(end);

if tF <= t0
    tF = t0 + dt*(nRaw-1);
end

t = (t0:dt:tF)';

if numel(t) < 2
    t = [t0; t0+dt];
end

N = numel(t);

theta_ref = interp1(t_raw, theta_ref_raw, t,'linear','extrap');
z_ref     = interp1(t_raw, z_ref_raw,     t,'linear','extrap');

isHel = interp1(t_raw, double(isHelical_raw), t,'nearest','extrap') > 0.5;
isReverse = interp1(t_raw, double(isReverse_raw), t,'nearest','extrap') > 0.5;

localSpeedPct   = interp1(t_raw, localSpeedPct_raw,   t,'nearest','extrap');
limitScalePct   = interp1(t_raw, limitScalePct_raw,   t,'linear','extrap');
mandrelSpeedPct = interp1(t_raw, mandrelSpeedPct_raw, t,'nearest','extrap');

theta_ref = theta_ref(:);
z_ref     = z_ref(:);

isHel     = isHel(:);
isReverse = isReverse(:);

localSpeedPct   = localSpeedPct(:);
limitScalePct   = limitScalePct(:);
mandrelSpeedPct = mandrelSpeedPct(:);

if zeroSpeedMode
    theta_ref(:) = theta_ref(1);
    z_ref(:)     = z_ref(1);
    localSpeedPct(:) = 0;
    limitScalePct(:) = 0;
    mandrelSpeedPct(:) = 0;
end

fw = max(5, min(120, floor(N/10)));

%  8. DIAMETRO DEL CILINDRO
%% -----------------------------------------------------------------------

D_mm = read_param_from_excel(xlsxFile, ...
    {'D_mm','D1_mm','Diameter','Diametro'}, NaN);

if isnan(D_mm) || D_mm <= 0
    warning('Diametro no encontrado en XLSX. Se usa D = 200 mm.');
    D_mm = 200;
end

R_mm = D_mm / 2;

%  9. PARAMETROS FISICOS
%% -----------------------------------------------------------------------

% Mandril: SGM7G 5.5 kW + reduccion 10:1
MandrelReduction         = 10;
MandrelMotorTorqueNom_Nm = 35;
MandrelMotorTorqueMax_Nm = 102;
MandrelMotorInertia_kgm2 = 89e-4;
J_mandril_total          = 22.73;

% Carrito: SGM7A 1.5 kW + reduccion 5:1
CarriageReduction         = 5;
CarriageMotorTorqueNom_Nm = 4.9;
CarriageMotorTorqueMax_Nm = 14.7;
CarriageMotorInertia_kgm2 = 2e-4;
J_carrito_total           = 0.673;

J_motor_m_ref = MandrelMotorInertia_kgm2 * MandrelReduction^2;
J_motor_s_ref = CarriageMotorInertia_kgm2 * CarriageReduction^2;

J_m_eq = J_mandril_total + J_motor_m_ref;
J_s_eq = J_carrito_total + J_motor_s_ref;

T_m_nom = MandrelMotorTorqueNom_Nm * MandrelReduction;
T_m_max = MandrelMotorTorqueMax_Nm * MandrelReduction;

T_s_nom = CarriageMotorTorqueNom_Nm * CarriageReduction;
T_s_max = CarriageMotorTorqueMax_Nm * CarriageReduction;

tau_m = 0.35;
tau_s = 0.04;

%  10. PID
%% -----------------------------------------------------------------------

Kp_m = 4.5;
Ki_m = 0.18;
Kd_m = 0.12;

Kp_s = 12.0;
Ki_s = 0.18;
Kd_s = 0.04;


%  11. K_SYNC LOCAL
%% -----------------------------------------------------------------------

dTheta_ref = [0; diff(theta_ref)];
dZ_ref     = [0; diff(z_ref)];

K_sync_raw = zeros(N,1);
msk = abs(dTheta_ref) > 1e-9;
K_sync_raw(msk) = dZ_ref(msk) ./ dTheta_ref(msk);

K_max = pi * D_mm / 360 * 15;
K_sync_raw = max(-K_max, min(K_max, K_sync_raw));

sw = min(51, max(3, floor(N/100)));

if mod(sw,2) == 0
    sw = sw + 1;
end

K_sync = movmean(K_sync_raw, sw);
K_sync = fill_nearest(K_sync, msk);

dtot = theta_ref(end) - theta_ref(1);

if abs(dtot) > 1e-9
    K_sync_global = (z_ref(end)-z_ref(1))/dtot;
else
    K_sync_global = 0;
end

%  11B. VARIABLES DE S-CURVE DEL CARRITO
%% -----------------------------------------------------------------------

z_min  = min(z_ref);
z_max  = max(z_ref);
z_span = z_max - z_min;

decel_dist = max(z_span * SCurve_decel_pct, SCurve_decel_min);

dist_to_limit = min(z_ref - z_min, z_max - z_ref);
dist_to_limit = max(dist_to_limit, 0);

q_limit = dist_to_limit ./ max(decel_dist, eps);
q_limit = max(0, min(1, q_limit));

v_scale = SCurve_limit_min_pct + ...
    (1 - SCurve_limit_min_pct) .* smootherstep(q_limit);

v_scale = max(SCurve_limit_min_pct, min(1, v_scale));

z_ref_original = z_ref;

% Limite local seguro del carrito
vLimitSafe_mm_s = CarriageMax_mm_s .* (localSpeedPct/100) ./ SyncSafetyFactor;
vLimitSafe_mm_s = max(vLimitSafe_mm_s, 1e-6);

a_max_carrito = min(max(T_s_max * 1000 / J_s_eq, 100), ...
                    CarriageMax_mm_s * 5);

jerk_max = a_max_carrito / max(3*dt, 0.01);

fprintf('[S-CURVE CARRITO] Zona decel = %.1f mm | minScale = %.1f%% | a_max = %.1f mm/s2 | jerk_max = %.0f mm/s3\n', ...
    decel_dist, SCurve_limit_min_pct*100, a_max_carrito, jerk_max);

%  12. SIMULACION MAESTRO-ESCLAVO
%% -----------------------------------------------------------------------

useCtrl = exist('tf','file') == 2 && exist('lsim','file') == 2;

if useCtrl

    fprintf('[INFO] Usando Control System Toolbox.\n');

    s = tf('s');

    Gm = (1/J_m_eq) / (s^2 + s/tau_m);
    Gs = (1/J_s_eq) / (s^2 + s/tau_s);

    Cm = Kp_m + Ki_m/s + Kd_m*s/(0.01*s+1);
    Cs = Kp_s + Ki_s/s + Kd_s*s/(0.01*s+1);

    Tm = feedback(Cm*Gm, 1);
    Ts = feedback(Cs*Gs, 1);

    theta_real = rad2deg(lsim(Tm, deg2rad(theta_ref), t));
    theta_real = theta_real(:);

    theta_error = theta_real - theta_ref;
    v_ref_ff = gradient(z_ref, dt);

    z_cmd_nom = z_ref + K_sync .* theta_error + tau_s .* v_ref_ff;
    z_cmd_nom = min(max(z_cmd_nom, z_min), z_max);

    z_cmd = apply_carriage_scurve_limiter( ...
        z_cmd_nom, z_ref(1), vLimitSafe_mm_s, dt, z_min, z_max);

    z_real = lsim(Ts, z_cmd, t);
    z_real = z_real(:);
    z_real = min(max(z_real, z_min), z_max);

else

    fprintf('[INFO] Sin Control System Toolbox. Usando primer orden discreto.\n');

    [theta_real, z_real, z_cmd, z_cmd_nom] = sim_primer_orden_anclado( ...
        theta_ref, z_ref, K_sync, dt, tau_m, tau_s, ...
        z_min, z_max, vLimitSafe_mm_s);

    Gm = [];
    Gs = [];
    Cm = [];
    Cs = [];
    Tm = [];
    Ts = [];

end

%  13. ERRORES
%% -----------------------------------------------------------------------

e_theta = theta_real - theta_ref;
e_z     = z_real     - z_ref;
e_sync  = z_real     - z_cmd;
e_cont  = sqrt(e_z.^2 + (R_mm.*deg2rad(e_theta)).^2);

e_sync_filt = movmean(e_sync, fw);
e_sync_rms  = sqrt(movmean(e_sync.^2, fw));

%  14. VELOCIDADES Y ACELERACIONES
%% -----------------------------------------------------------------------

omega_ref_rpm  = gradient(theta_ref,  dt) * 60/360;
omega_real_rpm = gradient(theta_real, dt) * 60/360;

omega_ref_rad_s  = omega_ref_rpm  * 2*pi/60;
omega_real_rad_s = omega_real_rpm * 2*pi/60;

alpha_ref_rpm_s  = gradient(omega_ref_rpm,  dt);
alpha_real_rpm_s = gradient(omega_real_rpm, dt);

jerk_rot      = gradient(alpha_ref_rpm_s, dt);
jerk_rot_filt = movmean(jerk_rot, fw);

v_ref_mm_s     = gradient(z_ref,     dt);
v_cmd_nom_mm_s = gradient(z_cmd_nom, dt);
v_cmd_mm_s     = gradient(z_cmd,     dt);
v_real_mm_s    = gradient(z_real,    dt);

a_ref_mm_s2  = gradient(v_ref_mm_s,  dt);
a_cmd_mm_s2  = gradient(v_cmd_mm_s,  dt);
a_real_mm_s2 = gradient(v_real_mm_s, dt);

jerk_lin      = gradient(a_cmd_mm_s2, dt);
jerk_lin_filt = movmean(jerk_lin, fw);

Mandrel_pct  = abs(omega_ref_rpm) / MandrelMax_rpm * 100;
Carriage_pct = abs(v_cmd_mm_s)    / CarriageMax_mm_s * 100;

rpm_plot_max = max(max(abs([omega_ref_rpm; omega_real_rpm])) * 1.3, 0.5);
v_plot_max   = max(max(abs([v_ref_mm_s; v_cmd_mm_s; v_real_mm_s])) * 1.3, 0.5);
pct_plot_max = min(max(max([Mandrel_pct; Carriage_pct; localSpeedPct; mandrelSpeedPct])*1.3, 2), 110);

%  15. ACCIONES DE CONTROL
%% -----------------------------------------------------------------------

tw = min(25, max(3, floor(N/200)));

e_th_f = movmean(e_theta, tw);
e_z_f  = movmean(e_z, tw);

ie_th = cumtrapz(t, e_th_f);
ie_z  = cumtrapz(t, e_z_f);

de_th = gradient(e_th_f, dt);
de_z  = gradient(e_z_f, dt);

u_m = Kp_m*e_th_f + Ki_m*ie_th + Kd_m*de_th;
u_s = Kp_s*e_z_f  + Ki_s*ie_z  + Kd_s*de_z;

u_m_norm = u_m / max(max(abs(u_m)), 1e-9);
u_s_norm = u_s / max(max(abs(u_s)), 1e-9);

%  16. TENDENCIAS
%% -----------------------------------------------------------------------

tw2 = min(40, max(5, floor(N/200)));

z_ref_m_trend  = movmean(z_ref/1000, tw2);
z_cmd_m_trend  = movmean(z_cmd/1000, tw2);
z_real_m_trend = movmean(z_real/1000, tw2);

vx_ref_norm  = movmean(v_ref_mm_s, tw2)  / CarriageMax_mm_s;
vx_cmd_norm  = movmean(v_cmd_mm_s, tw2)  / CarriageMax_mm_s;
vx_real_norm = movmean(v_real_mm_s, tw2) / CarriageMax_mm_s;

w_ref_rad_trend  = movmean(omega_ref_rad_s, tw2);
w_real_rad_trend = movmean(omega_real_rad_s, tw2);

u_m_trend = movmean(u_m_norm, tw2);
u_s_trend = movmean(u_s_norm, tw2);

%  17. COORDENADAS 3D
% ------------------------------------------------------------------------
%  Referencia ideal y trayectoria real corregida.
%% -----------------------------------------------------------------------

x3_ref = z_ref;
y3_ref = R_mm .* cosd(theta_ref);
z3_ref = R_mm .* sind(theta_ref);

x3 = z_real;
y3 = R_mm .* cosd(theta_real);
z3 = R_mm .* sind(theta_real);

%  FIGURA 1: TENDENCIAS DE CONTROL
%% =======================================================================

figure('Name', sprintf('Tendencias - Speed %.0f%% / Hel %.0f%%', ...
    SpeedPercent, HelicalSpeedPercent), 'NumberTitle','off');

subplot(4,1,1);
plot(t, z_ref_m_trend,  'b',   'LineWidth',1.2);
hold on;
plot(t, z_cmd_m_trend,  'g:',  'LineWidth',1.2);
plot(t, z_real_m_trend, 'r--', 'LineWidth',1.3);
safe_yline(z_min/1000, '--k', sprintf('z_{min}=%.0fmm', z_min));
safe_yline(z_max/1000, '--k', sprintf('z_{max}=%.0fmm', z_max));
grid on;
ylabel('x [m]');
title('Posicion carrito: referencia, comando seguro y respuesta real');
legend('Referencia','Comando seguro','Real','Location','best');
mark_limit_zones(t, limitScalePct);
mark_helical_zones(t, isHel);

subplot(4,1,2);
plot(t, vx_ref_norm,  'b',   'LineWidth',1.1);
hold on;
plot(t, vx_cmd_norm,  'g:',  'LineWidth',1.3);
plot(t, vx_real_norm, 'r--', 'LineWidth',1.3);
safe_yline( 1,'--k','');
safe_yline(-1,'--k','');
safe_yline( 0,'-k','');
grid on;
ylabel('v_x / v_{max}');
ylim([-1.15, 1.15]);
title('Velocidad carrito: helicoidal + S-curve en limites');
legend('Ref ideal','Cmd seguro','Real','Location','best');
mark_limit_zones(t, limitScalePct);
mark_helical_zones(t, isHel);

subplot(4,1,3);
plot(t, w_ref_rad_trend,  'k--','LineWidth',1.3);
hold on;
plot(t, w_real_rad_trend, 'm',  'LineWidth',1.3);
safe_yline( MandrelMax_rad_s,'--r','');
safe_yline(-MandrelMax_rad_s,'--r','');
safe_yline(0,'-k','');
grid on;
ylabel('\omega_z [rad/s]');
ylim([-MandrelMax_rad_s*1.15, MandrelMax_rad_s*1.15]);
title('Mandril: baja en helicoidales, no baja por limites del carrito');
legend('\omega ref','\omega real');
mark_helical_zones(t, isHel);

subplot(4,1,4);
plot(t, u_m_trend, 'b', 'LineWidth',1.3);
hold on;
plot(t, u_s_trend, 'm', 'LineWidth',1.3);
safe_yline( 1,'--k','');
safe_yline(-1,'--k','');
safe_yline( 0,'-k','');
grid on;
xlabel('t [s]');
ylabel('u [-]');
ylim([-1.15,1.15]);
title('Acciones de control normalizadas');
legend('u mandril','u carrito');
